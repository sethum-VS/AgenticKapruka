# AgenticKapruka — environment variables
# Copy to .env for local development:  cp .env.example .env
# Never commit .env (real secrets). This file uses placeholders only.
#
# ── Local development ─────────────────────────────────────────────────────────
# Run Redis Stack locally (RediSearch required for LangGraph checkpointer):
#   docker run -d -p 6379:6379 redis/redis-stack-server:latest
# Neo4j AuraDB, Zep Cloud, and Google API keys come from their
# respective consoles.
#
# ── Google Cloud Run (production) ─────────────────────────────────────────────
# Store secrets in Secret Manager and map them with --set-secrets on deploy.
# Memorystore for Redis is reachable only from your VPC — Cloud Run must use
# a Serverless VPC Access connector on the same VPC/subnet as the instance:
#
#   gcloud compute networks vpc-access connectors create agentic-kapruka-connector \
#     --region=REGION --network=default --range=10.8.0.0/28
#
#   gcloud run deploy agentic-kapruka \
#     --vpc-connector=agentic-kapruka-connector \
#     --vpc-egress=private-ranges-only \
#     --set-secrets=REDIS_URL=redis-url:latest,...
#
# Use rediss:// for TLS to Memorystore when AUTH is enabled. Neo4j AuraDB and
# Zep Cloud are reached over the public internet (no VPC connector required).

# ── Redis (Memorystore / local) ───────────────────────────────────────────────
# Required. Session cache, rate limits, LangGraph checkpointer, cart state.
# Local: redis://localhost:6379/0
# Memorystore (private IP, via VPC connector): rediss://10.x.x.x:6378/0
REDIS_URL=redis://localhost:6379/0

# ── Neo4j AuraDB ──────────────────────────────────────────────────────────────
# Required. GraphRAG ontology and vector search. Create a free Aura instance at
# https://neo4j.com/cloud/aura/ and copy the connection URI and credentials.
NEO4J_URI=bolt+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ── Zep Cloud ─────────────────────────────────────────────────────────────────
# Required. Long-term conversational memory across sessions.
# https://www.getzep.com/
ZEP_API_KEY=your-zep-api-key

# ── Google AI / Vertex AI ─────────────────────────────────────────────────────
# Gemini chat and embeddings use Vertex AI with Application Default Credentials.
# Local: gcloud auth application-default login
#   or: export GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
# Cloud Run: attach a service account with roles/aiplatform.user (no API key).
GEMINI_BACKEND=vertex
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
# Optional — only when GEMINI_BACKEND=api_key (Gemini Developer API / AI Studio):
# GOOGLE_API_KEY=your-google-ai-api-key

# ── Kapruka MCP ───────────────────────────────────────────────────────────────
# Optional. Public Kapruka MCP JSON-RPC endpoint (default shown).
KAPRUKA_MCP_URL=https://mcp.kapruka.com/mcp

# ── Application security ──────────────────────────────────────────────────────
# Required. Signs session cookies; minimum 32 characters. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=replace-with-at-least-32-random-characters
